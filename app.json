{
  "expo": {
    "name": "echo",
    "slug": "echo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/echo.png",
    "scheme": "echo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "dev.explysm.echo",
      "permissions": [
        "NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/echo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/echo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "baseUrl": "/echo",
      "favicon": "./assets/images/echo.png",
      "pwa": {
        "display": "standalone",
        "background_color": "#ffffff",
        "theme_color": "#000000",
        "description": "A minimalist, open-source lyric editor for creating, syncing, and publishing time-tagged lyrics to LRCLIB.",
        "name": "Echo - Minimalist Lyric Editor",
        "shortName": "Echo"
      }
    },

    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-updates",
        {
          "checkOnLaunch": "NEVER"
        }
      ],
      "./plugins/withJitPackFixed"
    ],
    "updates": {
      "url": "https://explysm.github.io/echo",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/echo"
    }
  }
}
